  "training": {
    "exercise_library": {
      "Sentadilla": "Pies a la anchura de los hombros, barra sobre trapecios, descender controladamente hasta que los muslos estén paralelos al suelo.",
      "Peso Muerto": "Barra cerca de las espinillas, espalda recta, empujar con los talones al levantar.",
      "Press Banca": "Barra sobre el pecho, codos a 45°, bajar controladamente hasta tocar el pecho.",
      "Press Militar": "Barra desde el pecho hasta extensión completa de brazos, core activado.",
      "Dominadas": "Agarre prono, subir hasta que la barbilla supere la barra, controlar el descenso.",
      "Fondos": "En paralelas, bajar hasta 90° de flexión de codo, empujar hasta extensión.",
      "Curl de Bíceps": "Codos fijos al costado, subir el peso sin balancear el cuerpo.",
      "Extensión de Tríceps": "Codo fijo, extender el antebrazo hasta la extensión completa.",
      "Prensa de Piernas": "Pies en la plataforma a la anchura de los hombros, no bloquear rodillas.",
      "Hip Thrust": "Espalda sobre banco, barra sobre caderas, empujar hacia arriba apretando glúteos.",
      "Peso Muerto Rumano": "Piernas semi-rígidas, barra cerca del cuerpo, sentir el estiramiento en isquiotibiales.",
      "Zancadas": "Paso largo hacia adelante, rodilla trasera casi toca el suelo, empujar con el talón delantero.",
      "Elevación de Gemelos": "En máquina o con mancuernas, subir sobre las puntas de los pies.",
      "Plancha": "Antebrazos en el suelo, cuerpo en línea recta, core activado 30-60 seg.",
      "Face Pull": "Cuerda a la altura de la cara, tirar hacia la frente, codos altos.",
      "Remo con Barra": "Espalda recta, tirar la barra hacia el abdomen inferior, apretar omóplatos.",
      "Remo Unilateral": "Mancuerna, apoyar mano y rodilla en banco, tirar hacia la cadera.",
      "Pull-over": "Mancuerna con ambas manos, brazos extendidos sobre el pecho, descender detrás de la cabeza.",
      "Curl Martillo": "Mancuernas en agarre neutro, alternar brazos.",
      "Patada de Tríceps": "Mancuerna, codo fijo a 90°, extender hacia atrás.",
      "Crunch": "Manos detrás de la cabeza, elevar hombros del suelo sin tirar del cuello.",
      "Elevación de Piernas": "Acostado boca arriba, elevar piernas rectas hasta 90°.",
      "Press de Piernas": "Máquina, pies en la plataforma, empujar sin bloquear rodillas.",
      "Abducción de Cadera": "Máquina, abrir piernas contra resistencia apretando glúteos.",
      "Adducción de Cadera": "Máquina, juntar piernas contra resistencia.",
      "Press de Hombros con Mancuernas": "Sentado, mancuernas a la altura de los hombros, empujar hacia arriba.",
      "Elevación Lateral": "Mancuernas, elevar brazos hasta la altura de los hombros, codos ligeramente flexionados.",
      "Elevación Frontal": "Mancuernas, elevar brazos al frente hasta la altura de los hombros.",
      "Encogimiento de Hombros": "Barra o mancuernas, elevar hombros hacia las orejas.",
      "Pulldown": "Agarre ancho, tirar la barra hacia la parte superior del pecho.",
      "Remo en Máquina": "Sentado, agarre neutro, tirar hacia el abdomen apretando omóplatos.",
      "Curl en Máquina": "Bíceps en la almohadilla, subir el brazo sin mover el codo."
    },
